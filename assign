<!doctype html>
<html lang="en">
  <head>
    <title>Assignment</title>
    <script>
      let num = prompt("Enter a number:");

      for (i = 1; i <= num; i++) {
        if (i % 3 == 0) {
          continue;
        }
        document.write("" + i + "<br>");
      }

      // do- while loop
      do {
        if (i % 3 === 0) {
          i++;
          continue; // Skip multiples of 3
        }

        document.write(i);
        i++;
      } while (i <= num);

      //  while loop
      let i = 1;

      while (i <= num) {
        if (i % 3 == 0) {
          i++;
          continue;
        }
        document.write("" + i + "<br>");
        i++;
      }
    </script>
  </head>
  <body></body>
</html>
